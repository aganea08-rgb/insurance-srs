@startuml


|Клиент|
start
:Подать заявку;
note right
POST/application/statement
end note
|Сервер|
:запросить список документов;
note right
GET/application/form/statement
end note

|Клиент|
:отправка документов;

|Сервер|
if (Документы подгружены?) then (нет)
  |Клиент|
  :документы не соответствуют формату;
  note right
  400 Bad Request error
  end note
  
  
    |Клиент|
    repeat
    :Отправить документы;
    note right
    POST/documents/upload
    end note
  repeat while (Документы не полные?) is (да)

  
else (да)
  |Сервер|
  :отправка документов;
endif

|Сервер|
  :проверка документов;
  fork
    |Сервер|
    :Отправить документы на проверку в ГИБДД;
  fork again
    |Сервер|
    :Отправить запрос в АИС на расчет КБМ;
  end fork
  |Сервер|
   
  if (ответ получен?) then (нет)
   |Сервер|
   :повторный запрос;
   repeat
   : повторный запрос до 3х раз;
   repeat while (ответ получен?) is (нет)
  
   |Сервер|
   :нет ответа;
   |Клиент|
   :сервер временно не доступен;
   note right
   504 Gateway Time Out error
   end note
   end 
  else (да)
   |Сервер|
   :расчет стоимости полиса;
   endif 
   
  :отображает стоимость полиса;   
|Клиент|
if (стоимость страхового полиса устраивает?) then (нет)
:отказ от заключения договора;
 end 
else (да)
:подписание договора;
endif
|Клиент|
:оплатить договор;
note right
POST/payments/initiate
{"contractId": "123", "amount": 5000}
end note

|Сервер|
:показывает форму оплаты;
note right
GET/payments/form/{paymentId}
end note

|Клиент|
:вводит данные для оплаты;
note right
POST/payments/initiate
{"cardNumber": "****", "expiry": "12/30", "cvv": "***"}
end note

|Сервер|
if (данные карты отвечают требованиям?)  then (нет)
|Клиент|
:400 Bad Request неверные данные;
repeat
:повторный ввод данных карты;
repeat while (Данные карты верные?) is (нет)


else (да)
|Сервер|
 if (на карте есть деньги?)  then (нет)
 |Клиент|
 :недостаточно средств;
  note right
  402 Payment Required error
  end note
repeat
:ввести данные другой карты;
repeat while (Данные карты верные?) is (нет)

 else (да)
 |Сервер|
 :списание средств;  
endif
endif
|Сервер|
:повторня попытка оплаты;

|Клиент|
:договор оплачен;
|Сервер|
:договор заключен;
fork
:отправка данных в АИС;
fork again
:формирование полиса в pdf;
end fork
:отправка полиса на email;

|Клиент|
:получен полис на email;

stop
@enduml